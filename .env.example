PORT=5000
MONGO_URI=<your_mongo_db_uri>
JWT_SECRET=<your_secret>
PAYPAL_CLIENT_ID=<your_paypal_client_id>
PAYPAL_APP_SECRET=<your_paypal_secret>
PAYPAL_API_URL=https://api-m.sandbox.paypal.com

# =============================================================================
# LLM Agent Configuration
# =============================================================================
# Change LLM_PROVIDER and LLM_BASE_URL to switch between providers.
# The openai-compatible adapter works with any OpenAI-compatible API.

# --- Option 1: Z.ai glm-4.7-flashx (DEFAULT — cheapest for demos) ---
LLM_PROVIDER=openai-compatible
LLM_BASE_URL=https://open.z.ai/api/paas/v4
LLM_MODEL=glm-4.7-flashx
LLM_API_KEY=your-z-ai-api-key

# --- Option 2: Z.ai glm-4.7-flash (free tier) ---
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://open.z.ai/api/paas/v4
# LLM_MODEL=glm-4.7-flash
# LLM_API_KEY=your-z-ai-api-key

# --- Option 3: Groq + Llama 3.3 70B (fastest inference) ---
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.groq.com/openai/v1
# LLM_MODEL=llama-3.3-70b-versatile
# LLM_API_KEY=your-groq-api-key

# --- Option 4: OpenAI GPT-4o (premium quality) ---
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_API_KEY=sk-your-openai-key

# --- Option 5: Anthropic Claude Sonnet (best tool calling — uses different adapter) ---
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-20250514
# LLM_API_KEY=sk-ant-your-anthropic-key
# LLM_BASE_URL=  (not needed for Anthropic — uses SDK default)

# --- Option 6: Ollama local (development — no API key needed) ---
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3.2
# LLM_API_KEY=ollama

# --- Common LLM settings (apply to all providers) ---
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0
LLM_STREAMING=true
LLM_COST_TRACKING=true
LLM_MAX_ITERATIONS=10
LLM_TIMEOUT_MS=30000
